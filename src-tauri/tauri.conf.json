{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hubnity",
  "version": "0.2.0",
  "identifier": "com.balabiturembek.hubnity",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hubnity",
        "width": 380,
        "height": 450,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0NjFFQkNCRUU0RjM4QTYKUldTbU9FL3V5K3RodElIUEFrSlZKZXlXUEtjS1NVNGY5NGFZVi9oVXVBU3pIY0lPbXlzTW01RnYK",
      "endpoints": [
        "https://github.com/balabiturembekov/desktop-client/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
